{
  "name": "nohara/laravel-latex-editor",
  "description": "Pustaka input matematika LaTeX mandiri sebagai pengganti Wiris & CKEditor berbayar di Laravel.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Institusi Anda",
      "email": "admin@institusi.ac.id"
    }
  ],
  "require": {
    "php": "^8.0",
    "illuminate/support": "^9.0|^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Nohara\\LaravelLatexEditor\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Nohara\\LaravelLatexEditor\\LaravelLatexEditorServiceProvider"
      ]
    }
  }
}
