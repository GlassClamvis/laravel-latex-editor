{
  "name": "nohara/laravel-latex-editor",
  "description": "Pustaka input rumus matematika LaTeX mandiri yang bebas lisensi dan mudah diintegrasikan di Laravel.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "GlassClamvis",
      "email": "nohara.clamvis@gmail.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Nohara\\LaravelLatexEditor\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Nohara\\LaravelLatexEditor\\LaravelLatexEditorServiceProvider"
      ]
    }
  }
}